# Stage 2: Create a clean Ubuntu-based image for copying built files
FROM ubuntu:latest

# Install necessary packages
RUN apt-get update && apt-get install -y nodejs npm

# Copy your project files into the container
WORKDIR /hello-world-contract

# Clear the contents of the working directory
RUN rm -rf ./*

# Copy package.json and package-lock.json
COPY package*.json /hello-world-contract/

# Install dependencies
RUN npm install

COPY src /hello-world-contract/src/
COPY hp.cfg.override /hello-world-contract/
COPY .env /hello-world-contract/

# Build your project using the npm script instead of manual ncc build
RUN npm run buildLinux
